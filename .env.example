# Copy to .env and change the values. The stack runs without a .env file
# using the dev defaults baked into docker-compose.yml, which is acceptable
# only because everything binds to localhost.

# Signs Superset session cookies and encrypts stored DB credentials.
# Generate one with: openssl rand -base64 42
SUPERSET_SECRET_KEY=dev_only_change_me_in_env_file

# Superset admin login created by the superset-init service on first run.
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin_local

# Password for the ClickHouse "analytics" user (database "payments").
CLICKHOUSE_PASSWORD=analytics_local

# Password for the Postgres database that stores Superset metadata.
POSTGRES_PASSWORD=superset_metadata_local
