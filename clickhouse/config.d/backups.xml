<!-- Backup destination for the BACKUP / RESTORE SQL commands.
     Defines a local disk named "backups" at /backups (a named Docker volume,
     so backups survive container recreation and live outside the data
     volume they protect) and allows the backup engine to write there.
     Mounted as a single file into /etc/clickhouse-server/config.d/ so the
     image's own config.d entries (network bindings) stay untouched. -->
<clickhouse>
    <storage_configuration>
        <disks>
            <backups>
                <type>local</type>
                <path>/backups/</path>
            </backups>
        </disks>
    </storage_configuration>
    <backups>
        <allowed_disk>backups</allowed_disk>
        <allowed_path>/backups/</allowed_path>
    </backups>
</clickhouse>
